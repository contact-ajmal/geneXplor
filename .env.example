# Database
POSTGRES_USER=genexplor
POSTGRES_PASSWORD=genexplor_secret
POSTGRES_DB=genexplor
DATABASE_URL=postgresql+asyncpg://genexplor:genexplor_secret@postgres:5432/genexplor

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=86400

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000

# External APIs
ENSEMBL_BASE_URL=https://rest.ensembl.org
CLINVAR_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
UNIPROT_BASE_URL=https://rest.uniprot.org
GNOMAD_API_URL=https://gnomad.broadinstitute.org/api
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# NCBI API Key (optional, increases rate limits)
NCBI_API_KEY=
